$C = "../Common.ui";

$C.@PageOverlay {}

$C.@DecoratedContainer {
  Anchor: (Width: 860, Height: 660);

  #Title {
    Group {
      $C.@Title {
        @Text = %pixelbays.rpg.bank.selector.title;
      }
    }
  }

  #Content {
    LayoutMode: Top;
    Padding: (Full: 12);

    Label #MenuTitleLabel {
      Text: "";
      Style: (...$C.@DefaultLabelStyle, FontSize: 16, RenderBold: true);
      Anchor: (Bottom: 4);
    }

    Label #MenuSubtitleLabel {
      Text: "";
      Style: (...$C.@DefaultLabelStyle, FontSize: 12);
      Anchor: (Bottom: 8);
    }

    Label #StatusLabel {
      Text: "";
      Style: (...$C.@DefaultLabelStyle, FontSize: 12, RenderBold: true);
      Anchor: (Bottom: 10);
    }

    Group #OptionRow0 {
      LayoutMode: Top;
      Anchor: (Bottom: 10);
      Label #OptionTitle0 { Text: ""; Style: (...$C.@DefaultLabelStyle, FontSize: 11, RenderBold: true); Anchor: (Bottom: 4); }
      TextButton #OptionButton0 { Text: ""; Style: $C.@DefaultTextButtonStyle; Anchor: (Width: 400, Height: 40, Bottom: 4); }
      Label #OptionDescription0 { Text: ""; Style: (...$C.@DefaultLabelStyle, FontSize: 11); }
    }

    Group #OptionRow1 {
      LayoutMode: Top;
      Anchor: (Bottom: 10);
      Label #OptionTitle1 { Text: ""; Style: (...$C.@DefaultLabelStyle, FontSize: 11, RenderBold: true); Anchor: (Bottom: 4); }
      TextButton #OptionButton1 { Text: ""; Style: $C.@DefaultTextButtonStyle; Anchor: (Width: 400, Height: 40, Bottom: 4); }
      Label #OptionDescription1 { Text: ""; Style: (...$C.@DefaultLabelStyle, FontSize: 11); }
    }

    Group #OptionRow2 {
      LayoutMode: Top;
      Anchor: (Bottom: 10);
      Label #OptionTitle2 { Text: ""; Style: (...$C.@DefaultLabelStyle, FontSize: 11, RenderBold: true); Anchor: (Bottom: 4); }
      TextButton #OptionButton2 { Text: ""; Style: $C.@DefaultTextButtonStyle; Anchor: (Width: 400, Height: 40, Bottom: 4); }
      Label #OptionDescription2 { Text: ""; Style: (...$C.@DefaultLabelStyle, FontSize: 11); }
    }

    Group #OptionRow3 {
      LayoutMode: Top;
      Anchor: (Bottom: 10);
      Label #OptionTitle3 { Text: ""; Style: (...$C.@DefaultLabelStyle, FontSize: 11, RenderBold: true); Anchor: (Bottom: 4); }
      TextButton #OptionButton3 { Text: ""; Style: $C.@DefaultTextButtonStyle; Anchor: (Width: 400, Height: 40, Bottom: 4); }
      Label #OptionDescription3 { Text: ""; Style: (...$C.@DefaultLabelStyle, FontSize: 11); }
    }

    Group #OptionRow4 {
      LayoutMode: Top;
      Anchor: (Bottom: 10);
      Label #OptionTitle4 { Text: ""; Style: (...$C.@DefaultLabelStyle, FontSize: 11, RenderBold: true); Anchor: (Bottom: 4); }
      TextButton #OptionButton4 { Text: ""; Style: $C.@DefaultTextButtonStyle; Anchor: (Width: 400, Height: 40, Bottom: 4); }
      Label #OptionDescription4 { Text: ""; Style: (...$C.@DefaultLabelStyle, FontSize: 11); }
    }

    Group #OptionRow5 {
      LayoutMode: Top;
      Label #OptionTitle5 { Text: ""; Style: (...$C.@DefaultLabelStyle, FontSize: 11, RenderBold: true); Anchor: (Bottom: 4); }
      TextButton #OptionButton5 { Text: ""; Style: $C.@DefaultTextButtonStyle; Anchor: (Width: 400, Height: 40, Bottom: 4); }
      Label #OptionDescription5 { Text: ""; Style: (...$C.@DefaultLabelStyle, FontSize: 11); }
    }
  }
}

$C.@BackButton {}