$C = "../Common.ui";

Group {
  Anchor: (Width: 248, Height: 124, Bottom: 6);
  Padding: (Full: 6);
  Background: PatchStyle(Color: #000000(0.32));
  OutlineColor: #2F4156(0.85);
  OutlineSize: 1;

  Group #MemberAccent {
    Anchor: (Left: 0, Top: 4, Width: 8, Height: 8);
    Background: #8E98A6;
  }

  Label #MemberName {
    Text: "";
    Anchor: (Left: 14, Top: 0, Width: 122, Height: 16);
    Style: (...$C.@DefaultLabelStyle, FontSize: 12, RenderBold: true);
  }

  Label #MemberClass {
    Text: "";
    Anchor: (Left: 144, Top: 0, Width: 92, Height: 16);
    Style: (...$C.@DefaultLabelStyle, FontSize: 10, RenderBold: true);
  }

  Group #Effect0 {
    Visible: false;
    Anchor: (Left: 14, Top: 18, Width: 14, Height: 14);
    Background: PatchStyle(Color: #183A26(0.78));
    OutlineColor: #6ED88A(0.9);
    OutlineSize: 1;

    Group #Effect0Icon {
      Anchor: (Full: 1);
      Background: PatchStyle(Color: #ffffff(0));
    }
  }

  Group #Effect1 {
    Visible: false;
