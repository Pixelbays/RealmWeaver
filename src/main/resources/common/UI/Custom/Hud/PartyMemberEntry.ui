  Group #Bar0 {
    Anchor: (Top: 38, Width: 236, Height: 22);

    Label #Bar0Label {
      Text: "";
      Anchor: (Left: 0, Top: 0, Width: 40, Height: 10);
      Style: (...$C.@DefaultLabelStyle, FontSize: 9, RenderBold: true);
    }

    Label #Bar0Value {
      Text: "";
      Anchor: (Left: 152, Top: 0, Width: 84, Height: 10);
      Style: (...$C.@DefaultLabelStyle, FontSize: 9, RenderBold: true);
    }

    Group #Bar0Track {
      Anchor: (Left: 36, Top: 12, Width: 116, Height: 10);
      Background: PatchStyle(Color: #000000(0.52));
      OutlineColor: #000000(0.65);
      OutlineSize: 1;

      Group #Bar0Fill {
        Anchor: (Left: 0, Top: 0, Width: 0, Height: 10);
        Background: #4FD36F;
      }
    }
  }

  Group #Bar1 {
