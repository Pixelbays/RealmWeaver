$C = "../Common.ui";

Group {
  Anchor: (Width: 30, Height: 30, Right: 8);

  TextButton #Button {
    Anchor: (Full: 0);
    Padding: (Full: 0);
    Style: (
      Hovered: (Background: #ffffff(0.08)),
      Pressed: (Background: #ffffff(0.14))
    );
  }

  Group #SelectedHighlight {
    Visible: false;
    Anchor: (Width: 36, Height: 36, Top: -3, Left: -3);
    Background: "AvatarEditor/ColorOptionSelected.png";
  }

  Group #SwatchFill {
    LayoutMode: Left;
    Anchor: (Width: 30, Height: 30);
    Background: PatchStyle(Color: #ffffff(0));
    MaskTexturePath: "AvatarEditor/ColorOptionMask.png";
  }

  Group {
    Anchor: (Width: 30, Height: 30);
    Background: "AvatarEditor/ColorOptionFrame.png";
  }
}