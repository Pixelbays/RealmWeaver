$C = "../Common.ui";

Group {
  Anchor: (Width: 82, Height: 32, Right: 8);

  TextButton #Button {
    Anchor: (Full: 0);
    Padding: (Full: 0);
    Style: (
      Default: (Background: (TexturePath: "AvatarEditor/ButtonPatch.png", Border: 16)),
      Hovered: (Background: (TexturePath: "AvatarEditor/ButtonHoveredPatch.png", Border: 16)),
      Pressed: (Background: (TexturePath: "AvatarEditor/ButtonHoveredPatch.png", Border: 16))
    );
  }

  Label #Label {
    Text: "";
    Style: (...$C.@DefaultLabelStyle, FontSize: 10, RenderBold: true, RenderUppercase: true, HorizontalAlignment: Center, VerticalAlignment: Center);
    Anchor: (Full: 0);
  }

  Group #SelectedBadge {
    Visible: false;
    Anchor: (Width: 14, Height: 14, Right: 6, Top: 9);
    Background: (TexturePath: "AvatarEditor/EquippedIcon.png");
  }
}
