$C = "../Common.ui";

Group {
  Anchor: (Width: 52, Height: 58, Bottom: 6);
  Background: (TexturePath: "AvatarEditor/CategoryIconBackground.png");

  Group #SelectedBar {
    Visible: false;
    Anchor: (Width: 9, Height: 18, Right: -2, Top: 20);
    Background: (TexturePath: "AvatarEditor/SelectedCategoryArrow.png");
  }

  TextButton #Button {
    Anchor: (Full: 0);
    Padding: (Full: 0);
    Style: (Hovered: (Background: #2f3a4f(0.18)), Pressed: (Background: #2f3a4f(0.32)));
  }

  Group #BodyCharacteristicIcon { Visible: false; Anchor: (Width: 22, Height: 22, Left: 15, Top: 8); Background: (TexturePath: "AvatarEditor/CategoryIcons/BodyCharacteristic.png"); }
  Group #BodyCharacteristicSelectedIcon { Visible: false; Anchor: (Width: 22, Height: 22, Left: 15, Top: 8); Background: (TexturePath: "AvatarEditor/CategoryIcons/BodyCharacteristicSelected.png"); }
  Group #UnderwearIcon { Visible: false; Anchor: (Width: 22, Height: 22, Left: 15, Top: 8); Background: (TexturePath: "AvatarEditor/CategoryIcons/Underwear.png"); }
  Group #UnderwearSelectedIcon { Visible: false; Anchor: (Width: 22, Height: 22, Left: 15, Top: 8); Background: (TexturePath: "AvatarEditor/CategoryIcons/UnderwearSelected.png"); }
