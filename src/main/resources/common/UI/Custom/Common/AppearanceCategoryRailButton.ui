  Label #GlyphLabel {
    Visible: false;
    Text: "";
    Style: (...$C.@DefaultLabelStyle, FontSize: 15, RenderBold: true, HorizontalAlignment: Center);
    Anchor: (Height: 18, Bottom: 3);
  }

  Label #TitleLabel {
    Text: "";
    Style: (...$C.@DefaultLabelStyle, FontSize: 8, RenderUppercase: true, HorizontalAlignment: Center, TextColor: #8ba0b6);
    Anchor: (Height: 12, Left: 2, Right: 2, Bottom: 5);
  }
}
