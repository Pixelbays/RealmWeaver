  Group #VariousSelectedIcon { Visible: false; Anchor: (Width: 22, Height: 22, Left: 15, Top: 8); Background: (TexturePath: "AvatarEditor/CategoryIcons/VariousSelected.png"); }
  Group #GlovesIcon { Visible: false; Anchor: (Width: 22, Height: 22, Left: 15, Top: 8); Background: (TexturePath: "AvatarEditor/CategoryIcons/Gloves.png"); }
  Group #GlovesSelectedIcon { Visible: false; Anchor: (Width: 22, Height: 22, Left: 15, Top: 8); Background: (TexturePath: "AvatarEditor/CategoryIcons/GlovesSelected.png"); }
