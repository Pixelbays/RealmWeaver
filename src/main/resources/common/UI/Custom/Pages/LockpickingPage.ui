$C = "../Common.ui";

@PinInactiveColor = #1c2030;
@PinBarInactiveColor = #2e3050;
@PinDefaultOutline = #2a2d45;

$C.@PageOverlay {}

$C.@DecoratedContainer {
  Anchor: (Width: 620, Height: 300);

  #Title {
    Group {
      LayoutMode: Left;
      $C.@Title {
        @Text = %pixelbays.rpg.lockpicking.title;
      }
      Label #DifficultyLabel {
        Text: "";
        Style: (...$C.@DefaultLabelStyle, TextColor: #c0a840, RenderBold: true, FontSize: 13);
        Anchor: (Left: 14);
      }
    }
  }

  #Content {
    LayoutMode: Top;
    Padding: (Full: 16);

    // ── Pin indicators ──────────────────────────────────────────
    Group {
      Anchor: (Height: 76, Bottom: 10);
      LayoutMode: Left;

      Group { FlexWeight: 1; }

      Group #Pin0 {
        Anchor: (Width: 56, Height: 76);
        Padding: (Full: 3);
        Background: PatchStyle(Color: @PinInactiveColor);
        OutlineColor: @PinDefaultOutline;
        OutlineSize: 1.5;
        LayoutMode: CenterMiddle;
        Group #Pin0Bar {
          Anchor: (Width: 14, Height: 40);
          Background: PatchStyle(Color: @PinBarInactiveColor);
        }
      }

      Group { Anchor: (Width: 6); }

      Group #Pin1 {
        Anchor: (Width: 56, Height: 76);
        Padding: (Full: 3);
        Background: PatchStyle(Color: @PinInactiveColor);
        OutlineColor: @PinDefaultOutline;
        OutlineSize: 1.5;
        LayoutMode: CenterMiddle;
        Group #Pin1Bar {
          Anchor: (Width: 14, Height: 40);
          Background: PatchStyle(Color: @PinBarInactiveColor);
        }
      }

      Group { Anchor: (Width: 6); }

      Group #Pin2 {
        Anchor: (Width: 56, Height: 76);
        Padding: (Full: 3);
        Background: PatchStyle(Color: @PinInactiveColor);
        OutlineColor: @PinDefaultOutline;
        OutlineSize: 1.5;
        LayoutMode: CenterMiddle;
        Group #Pin2Bar {
          Anchor: (Width: 14, Height: 40);
          Background: PatchStyle(Color: @PinBarInactiveColor);
        }
      }

      Group { Anchor: (Width: 6); }

      Group #Pin3 {
        Anchor: (Width: 56, Height: 76);
        Padding: (Full: 3);
        Background: PatchStyle(Color: @PinInactiveColor);
        OutlineColor: @PinDefaultOutline;
        OutlineSize: 1.5;
        LayoutMode: CenterMiddle;
        Group #Pin3Bar {
          Anchor: (Width: 14, Height: 40);
          Background: PatchStyle(Color: @PinBarInactiveColor);
        }
      }

      Group { Anchor: (Width: 6); }

      Group #Pin4 {
        Anchor: (Width: 56, Height: 76);
        Padding: (Full: 3);
        Background: PatchStyle(Color: @PinInactiveColor);
        OutlineColor: @PinDefaultOutline;
        OutlineSize: 1.5;
        LayoutMode: CenterMiddle;
        Group #Pin4Bar {
          Anchor: (Width: 14, Height: 40);
          Background: PatchStyle(Color: @PinBarInactiveColor);
        }
      }

      Group { FlexWeight: 1; }
    }
    // ── Action buttons ───────────────────────────────────────────
    Group {
      LayoutMode: Center;
      Anchor: (Height: 44);

      TextButton #SetPinButton {
        Text: %pixelbays.rpg.lockpicking.setPin;
        Style: $C.@DefaultTextButtonStyle;
        Anchor: (Right: 10, Width: 220, Height: 44);
      }

      TextButton #CancelButton {
        Text: %pixelbays.rpg.lockpicking.cancel;
        Style: $C.@CancelTextButtonStyle;
        Anchor: (Width: 110, Height: 44);
      }
    }
    // ── Needle track ─────────────────────────────────────────────
    Group {
      Anchor: (Height: 36, Bottom: 8);
      LayoutMode: CenterMiddle;

      Group #TrackArea {
        Anchor: (Width: 520, Height: 28);
        Background: PatchStyle(Color: #0e1018);
        OutlineColor: #2a2d45;
        OutlineSize: 1;

        // Sweet-spot highlight (Anchor.Left + Anchor.Width updated from Java)
        Group #SweetSpot {
          Anchor: (Left: 0, Width: 60, Top: 2, Bottom: 2);
          Background: PatchStyle(Color: #1e5a30C0);
        }

        // Needle line (Anchor.Left updated from Java)
        Group #Needle {
          Anchor: (Left: 0, Width: 3, Top: 0, Bottom: 0);
          Background: PatchStyle(Color: #d4c89a);
        }
      }
    }

    // ── Info row: mistakes · pin progress · time remaining ───────
    Group {
      LayoutMode: Left;
      Anchor: (Height: 20, Bottom: 6);

      Label #MistakesLabel {
        Text: "0/0";
        Style: (...$C.@DefaultLabelStyle, FontSize: 12);
      }

      Group { FlexWeight: 1; }

      Label #PinLabel {
        Text: "Pin 0/0";
        Style: (...$C.@DefaultLabelStyle, FontSize: 12);
      }

      Group { FlexWeight: 1; }

      Label #TimeLabel {
        Text: "0.0s";
        Style: (...$C.@DefaultLabelStyle, FontSize: 12);
      }

      Group { FlexWeight: 1; }

      Label #LockpicksLabel {
        Text: "Picks: 0";
        Style: (...$C.@DefaultLabelStyle, FontSize: 12);
      }
    }

    // ── Timer bar ─────────────────────────────────────────────────
    Group {
      Anchor: (Height: 6, Bottom: 14);
      Background: PatchStyle(Color: #1a1c2a);
      Group #TimerFill {
        Anchor: (Left: 0, Top: 0, Bottom: 0, Width: 520);
        Background: PatchStyle(Color: #3a6aaa);
      }
    }


  }
}

$C.@BackButton {}
