$C = "../Common.ui";

@TreeTabSlot = TextButton {
  Text: "";
  Style: $C.@DefaultTextButtonStyle;
  Anchor: (Width: 0, Height: 0, Right: 0);
};

@TreeConnectorSlot = Group {
  Anchor: (Width: 0, Height: 0);
  Background: #4d5c72(0.45);
};

@TalentNodeSlot = Group {
  Anchor: (Width: 0, Height: 0);
  TextButton #NodeButton {
    Text: "";
    Style: $C.@DefaultTextButtonStyle;
    Anchor: (Left: 0, Top: 0, Width: 0, Height: 0);
  }

  Label #NodeTitle {
    Text: "";
    Style: (...$C.@DefaultLabelStyle, RenderBold: true, FontSize: 12, HorizontalAlignment: Center, Wrap: true);
    Anchor: (Left: 0, Top: 0, Width: 0, Height: 0);
  }

  Label #NodeRank {
    Text: "";
    Style: (...$C.@DefaultLabelStyle, FontSize: 11, HorizontalAlignment: Center);
    Anchor: (Left: 0, Top: 0, Width: 0, Height: 0);
  }

  Label #NodeState {
    Text: "";
    Style: (...$C.@DefaultLabelStyle, FontSize: 10, HorizontalAlignment: Center);
    Anchor: (Left: 0, Top: 0, Width: 0, Height: 0);
  }
};

$C.@PageOverlay {}

$C.@DecoratedContainer {
  Anchor: (Width: 1400, Height: 720);

  #Title {
    Group {
      $C.@Title {
        @Text = %pixelbays.rpg.talent.ui.title;
      }
    }
  }

  #Content {
    LayoutMode: Top;
    Padding: (Full: 12);

    // Header: class name + points summary
    Group #HeaderRow {
      Anchor: (Height: 26, Bottom: 8);
      LayoutMode: Left;

      Label #ClassName {
        Text: "";
        Style: (...$C.@DefaultLabelStyle, RenderBold: true, FontSize: 15);
        FlexWeight: 1;
      }

      Label #PointsLabel {
        Text: "";
        Style: (...$C.@DefaultLabelStyle, FontSize: 13);
      }
    }

    // Tree tab row — dynamically populated
    Group #TreeTabs {
      LayoutMode: Left;
      Anchor: (Height: 38, Bottom: 8);

      @TreeTabSlot #TreeTab0 {}
      @TreeTabSlot #TreeTab1 {}
      @TreeTabSlot #TreeTab2 {}
      @TreeTabSlot #TreeTab3 {}
      @TreeTabSlot #TreeTab4 {}
      @TreeTabSlot #TreeTab5 {}
      @TreeTabSlot #TreeTab6 {}
      @TreeTabSlot #TreeTab7 {}
    }

    // Main content row: tree canvas + detail panel
    Group #MainRow {
      LayoutMode: Left;
      FlexWeight: 1;

      // Left panel: scrollable tree canvas
      Group #TreePanel {
        Anchor: (Width: 1100);
        LayoutMode: Top;

        Label #TreeName {
          Text: "";
          Style: (...$C.@DefaultLabelStyle, RenderBold: true, FontSize: 13);
          Anchor: (Height: 22, Bottom: 6);
        }

        Label #TreeDescription {
          Text: "";
          Style: (...$C.@DefaultLabelStyle, FontSize: 12, Wrap: true);
          Anchor: (Height: 40, Bottom: 8);
        }

        Group #TreeViewport {
          FlexWeight: 1;
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;
          Padding: (Right: 6);
          Background: #0c1522(0.2);

          Group #TreeCanvas {
            Anchor: (Width: 0, Height: 0);
            Background: #08101a(0.35);

            @TreeConnectorSlot #Connector0 {}
            @TreeConnectorSlot #Connector1 {}
            @TreeConnectorSlot #Connector2 {}
            @TreeConnectorSlot #Connector3 {}
            @TreeConnectorSlot #Connector4 {}
            @TreeConnectorSlot #Connector5 {}
            @TreeConnectorSlot #Connector6 {}
            @TreeConnectorSlot #Connector7 {}
            @TreeConnectorSlot #Connector8 {}
            @TreeConnectorSlot #Connector9 {}
            @TreeConnectorSlot #Connector10 {}
            @TreeConnectorSlot #Connector11 {}
            @TreeConnectorSlot #Connector12 {}
            @TreeConnectorSlot #Connector13 {}
            @TreeConnectorSlot #Connector14 {}
            @TreeConnectorSlot #Connector15 {}
            @TreeConnectorSlot #Connector16 {}
            @TreeConnectorSlot #Connector17 {}
            @TreeConnectorSlot #Connector18 {}
            @TreeConnectorSlot #Connector19 {}
            @TreeConnectorSlot #Connector20 {}
            @TreeConnectorSlot #Connector21 {}
            @TreeConnectorSlot #Connector22 {}
            @TreeConnectorSlot #Connector23 {}
            @TreeConnectorSlot #Connector24 {}
            @TreeConnectorSlot #Connector25 {}
            @TreeConnectorSlot #Connector26 {}
            @TreeConnectorSlot #Connector27 {}
            @TreeConnectorSlot #Connector28 {}
            @TreeConnectorSlot #Connector29 {}
            @TreeConnectorSlot #Connector30 {}
            @TreeConnectorSlot #Connector31 {}
            @TreeConnectorSlot #Connector32 {}
            @TreeConnectorSlot #Connector33 {}
            @TreeConnectorSlot #Connector34 {}
            @TreeConnectorSlot #Connector35 {}
            @TreeConnectorSlot #Connector36 {}
            @TreeConnectorSlot #Connector37 {}
            @TreeConnectorSlot #Connector38 {}
            @TreeConnectorSlot #Connector39 {}
            @TreeConnectorSlot #Connector40 {}
            @TreeConnectorSlot #Connector41 {}
