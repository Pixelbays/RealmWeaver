            @TreeConnectorSlot #Connector84 {}
            @TreeConnectorSlot #Connector85 {}
            @TreeConnectorSlot #Connector86 {}
            @TreeConnectorSlot #Connector87 {}
            @TreeConnectorSlot #Connector88 {}
            @TreeConnectorSlot #Connector89 {}
            @TreeConnectorSlot #Connector90 {}
            @TreeConnectorSlot #Connector91 {}
            @TreeConnectorSlot #Connector92 {}
            @TreeConnectorSlot #Connector93 {}
            @TreeConnectorSlot #Connector94 {}
            @TreeConnectorSlot #Connector95 {}

            @TalentNodeSlot #NodeSlot0 {}
            @TalentNodeSlot #NodeSlot1 {}
            @TalentNodeSlot #NodeSlot2 {}
            @TalentNodeSlot #NodeSlot3 {}
            @TalentNodeSlot #NodeSlot4 {}
            @TalentNodeSlot #NodeSlot5 {}
            @TalentNodeSlot #NodeSlot6 {}
            @TalentNodeSlot #NodeSlot7 {}
            @TalentNodeSlot #NodeSlot8 {}
