            @TalentNodeSlot #NodeSlot41 {}
            @TalentNodeSlot #NodeSlot42 {}
            @TalentNodeSlot #NodeSlot43 {}
            @TalentNodeSlot #NodeSlot44 {}
            @TalentNodeSlot #NodeSlot45 {}
            @TalentNodeSlot #NodeSlot46 {}
            @TalentNodeSlot #NodeSlot47 {}
          }
        }
      }

      // Padding between panels
      Group { Anchor: (Width: 12); }

      // Right panel: node detail + actions
      Group #DetailPanel {
        FlexWeight: 1;
        LayoutMode: Top;
        Padding: (Full: 14);
        Background: #182640(0.15);

        Label #NodeName {
          Text: %pixelbays.rpg.talent.ui.selectNode;
          Style: (...$C.@DefaultLabelStyle, RenderBold: true, FontSize: 16, HorizontalAlignment: Center);
          Anchor: (Height: 26, Bottom: 6);
        }

        Label #NodeRankLabel {
          Text: "";
          Style: (...$C.@DefaultLabelStyle, FontSize: 13, HorizontalAlignment: Center);
          Anchor: (Height: 20, Bottom: 8);
        }

        Label #NodeDesc {
          Text: "";
          Style: (...$C.@DefaultLabelStyle, FontSize: 13, Wrap: true, HorizontalAlignment: Center);
          Anchor: (Height: 72, Bottom: 8);
        }

        Label #NodeReqLabel {
          Text: "";
          Style: (...$C.@DefaultLabelStyle, FontSize: 12, Wrap: true);
          Anchor: (Height: 36, Bottom: 6);
        }

        Label #NodeStatsLabel {
          Text: "";
          Style: (...$C.@DefaultLabelStyle, FontSize: 12, Wrap: true);
          Anchor: (Height: 48, Bottom: 6);
        }

        Group { FlexWeight: 1; }

        Label #StatusLabel {
          Text: "";
          Style: (...$C.@DefaultLabelStyle, FontSize: 13, HorizontalAlignment: Center, Wrap: true);
          Anchor: (Height: 36, Bottom: 8);
        }

        Group #ActionRow {
          Anchor: (Height: 40);
          LayoutMode: Left;

          TextButton #AllocateButton {
            Text: %pixelbays.rpg.talent.ui.allocate;
            Style: $C.@DefaultTextButtonStyle;
            FlexWeight: 1;
          }

          Group { Anchor: (Width: 8); }

          TextButton #ResetButton {
            Text: %pixelbays.rpg.talent.ui.reset;
            Style: $C.@DefaultTextButtonStyle;
            FlexWeight: 1;
          }
        }
      }
    }
  }
}

$C.@BackButton {}
