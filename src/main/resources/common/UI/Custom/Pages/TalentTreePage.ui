            @TreeConnectorSlot #Connector56 {}
            @TreeConnectorSlot #Connector57 {}
            @TreeConnectorSlot #Connector58 {}
            @TreeConnectorSlot #Connector59 {}
            @TreeConnectorSlot #Connector60 {}
            @TreeConnectorSlot #Connector61 {}
            @TreeConnectorSlot #Connector62 {}
            @TreeConnectorSlot #Connector63 {}
            @TreeConnectorSlot #Connector64 {}
            @TreeConnectorSlot #Connector65 {}
            @TreeConnectorSlot #Connector66 {}
