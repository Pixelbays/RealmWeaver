$C = "../Common.ui";

$C.@PageOverlay {}

$C.@DecoratedContainer {
  Anchor: (Width: 720, Height: 520);

  #Title {
    Group {
      $C.@Title {
        @Text = %pixelbays.rpg.party.ui.title;
      }
    }
  }

  #Content {
    LayoutMode: Top;
    Padding: (Full: 12);

    Label #StatusLabel {
      Text: "";
      Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true);
      Anchor: (Bottom: 12);
    }

    Group #RosterPanel {
      LayoutMode: Top;
      Anchor: (Bottom: 12);

      Label {
        Text: %pixelbays.rpg.party.ui.rosterHeading;
        Style: (...$C.@DefaultLabelStyle, RenderBold: true);
        Anchor: (Bottom: 6);
      }

      Label #RosterLabel {
        Text: "";
        Style: (...$C.@DefaultLabelStyle, FontSize: 12);
      }
    }

    Group #InviteRow {
      LayoutMode: Left;
      Anchor: (Height: 40, Bottom: 8);

      $C.@TextField #InviteeField {
        @Anchor = (Width: 400, Height: 40);
        PlaceholderText: %pixelbays.rpg.ui.placeholder.playerName;
      }

      Group { FlexWeight: 1; }

      TextButton #InviteButton {
        Text: %pixelbays.rpg.party.ui.inviteButton;
        Style: $C.@DefaultTextButtonStyle;
        Anchor: (Width: 160, Height: 40);
      }
    }

    Group #KickRow {
      LayoutMode: Left;
      Anchor: (Height: 40, Bottom: 8);

      $C.@TextField #KickField {
        @Anchor = (Width: 400, Height: 40);
        PlaceholderText: %pixelbays.rpg.ui.placeholder.playerName;
      }

      Group { FlexWeight: 1; }

      TextButton #KickButton {
        Text: %pixelbays.rpg.party.ui.kickButton;
        Style: $C.@DefaultTextButtonStyle;
        Anchor: (Width: 160, Height: 40);
      }
    }

    Group #PromoteRow {
      LayoutMode: Left;
      Anchor: (Height: 40, Bottom: 12);

      $C.@TextField #PromoteField {
        @Anchor = (Width: 400, Height: 40);
        PlaceholderText: %pixelbays.rpg.ui.placeholder.playerName;
      }

      Group { FlexWeight: 1; }

      TextButton #PromoteButton {
        Text: %pixelbays.rpg.party.ui.promoteButton;
        Style: $C.@DefaultTextButtonStyle;
        Anchor: (Width: 160, Height: 40);
      }
    }

    Group #BottomRow {
      LayoutMode: Left;
      Anchor: (Height: 44);

      TextButton #LeaveButton {
        Text: %pixelbays.rpg.party.ui.leaveButton;
        Style: $C.@CancelTextButtonStyle;
        Anchor: (Width: 160, Height: 44);
      }
    }
  }
}

$C.@BackButton {}
