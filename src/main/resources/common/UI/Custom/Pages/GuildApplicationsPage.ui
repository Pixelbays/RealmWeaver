$C = "../Common.ui";

$C.@PageOverlay {}

$C.@DecoratedContainer {
  Anchor: (Width: 860, Height: 660);

  #Title {
    Group {
      $C.@Title {
        @Text = %pixelbays.rpg.guild.applications.ui.title;
      }
    }
  }

  #Content {
    LayoutMode: Top;
    Padding: (Full: 12);

    Label #StatusLabel {
      Text: "";
      Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true);
      Anchor: (Bottom: 10);
    }

    Group {
      LayoutMode: Left;
      Anchor: (Height: 150, Bottom: 12);

      Group {
        FlexWeight: 1;
        LayoutMode: Top;
        Anchor: (Right: 10);

        Label {
          Text: %pixelbays.rpg.guild.applications.ui.inviteHeading;
          Style: (...$C.@DefaultLabelStyle, RenderBold: true);
          Anchor: (Bottom: 6);
        }

        Label #InviteSummaryLabel {
          Text: "";
          Style: (...$C.@DefaultLabelStyle, FontSize: 12);
          Anchor: (Bottom: 8);
        }

        Group #InviteActionRow {
          Visible: false;
          LayoutMode: Left;
          Anchor: (Height: 40);

          TextButton #AcceptInviteButton {
            Text: %pixelbays.rpg.guild.ui.acceptInviteButton;
            Style: $C.@DefaultTextButtonStyle;
            Anchor: (Width: 170, Height: 40, Right: 8);
          }

          TextButton #DeclineInviteButton {
            Text: %pixelbays.rpg.guild.ui.declineInviteButton;
            Style: $C.@CancelTextButtonStyle;
            Anchor: (Width: 170, Height: 40);
          }
        }
      }

      Group {
        FlexWeight: 1;
        LayoutMode: Top;

        Label {
          Text: %pixelbays.rpg.guild.applications.ui.currentApplicationHeading;
          Style: (...$C.@DefaultLabelStyle, RenderBold: true);
          Anchor: (Bottom: 6);
        }

        Label #CurrentApplicationLabel {
          Text: "";
          Style: (...$C.@DefaultLabelStyle, FontSize: 12);
        }
      }
    }

    Group {
      LayoutMode: Left;
      Anchor: (Height: 40, Bottom: 8);

      $C.@TextField #SearchField {
        @Anchor = (Width: 310, Height: 40, Right: 8);
        PlaceholderText: %pixelbays.rpg.guild.applications.ui.searchPlaceholder;
      }

      TextButton #SearchByNameButton {
        Text: %pixelbays.rpg.guild.applications.ui.searchByName;
        Style: $C.@DefaultTextButtonStyle;
        Anchor: (Width: 120, Height: 40, Right: 8);
      }

      TextButton #SearchByDescriptionButton {
        Text: %pixelbays.rpg.guild.applications.ui.searchByDescription;
        Style: $C.@DefaultTextButtonStyle;
        Anchor: (Width: 140, Height: 40, Right: 8);
      }

      TextButton #SearchButton {
        Text: %pixelbays.rpg.guild.applications.ui.searchButton;
        Style: $C.@DefaultTextButtonStyle;
        Anchor: (Width: 120, Height: 40);
      }
    }

    Group {
      LayoutMode: Top;
      Anchor: (Bottom: 10);

      Label {
        Text: %pixelbays.rpg.guild.applications.ui.resultsHeading;
        Style: (...$C.@DefaultLabelStyle, RenderBold: true);
        Anchor: (Bottom: 6);
      }

      Group #ResultPagerRow {
        Visible: false;
        LayoutMode: Left;
        Anchor: (Height: 40, Bottom: 8);

        TextButton #ResultPreviousButton {
          Text: %pixelbays.rpg.guild.ui.roleTabPreviousButton;
          Style: $C.@DefaultTextButtonStyle;
          Anchor: (Width: 44, Height: 40, Right: 8);
        }

        Label #ResultPageLabel {
          Text: "";
          Style: (...$C.@DefaultLabelStyle, FontSize: 12);
          Anchor: (Top: 12, Right: 8);
        }

        Group { FlexWeight: 1; }

        TextButton #ResultNextButton {
          Text: %pixelbays.rpg.guild.ui.roleTabNextButton;
          Style: $C.@DefaultTextButtonStyle;
          Anchor: (Width: 44, Height: 40);
        }
      }

      Group #ResultRow1 { Visible: false; LayoutMode: Left; Anchor: (Height: 40, Bottom: 6); TextButton #ResultButton1 { Text: ""; Style: $C.@DefaultTextButtonStyle; Anchor: (Width: 820, Height: 40); } }
      Group #ResultRow2 { Visible: false; LayoutMode: Left; Anchor: (Height: 40, Bottom: 6); TextButton #ResultButton2 { Text: ""; Style: $C.@DefaultTextButtonStyle; Anchor: (Width: 820, Height: 40); } }
      Group #ResultRow3 { Visible: false; LayoutMode: Left; Anchor: (Height: 40, Bottom: 6); TextButton #ResultButton3 { Text: ""; Style: $C.@DefaultTextButtonStyle; Anchor: (Width: 820, Height: 40); } }
      Group #ResultRow4 { Visible: false; LayoutMode: Left; Anchor: (Height: 40, Bottom: 6); TextButton #ResultButton4 { Text: ""; Style: $C.@DefaultTextButtonStyle; Anchor: (Width: 820, Height: 40); } }
      Group #ResultRow5 { Visible: false; LayoutMode: Left; Anchor: (Height: 40, Bottom: 8); TextButton #ResultButton5 { Text: ""; Style: $C.@DefaultTextButtonStyle; Anchor: (Width: 820, Height: 40); } }

      Group {
        Visible: false;
        LayoutMode: Left;
        Anchor: (Height: 1);

        $C.@TextField #ResultValueField1 { @Anchor = (Width: 1, Height: 1); }
        $C.@TextField #ResultValueField2 { @Anchor = (Width: 1, Height: 1); }
        $C.@TextField #ResultValueField3 { @Anchor = (Width: 1, Height: 1); }
        $C.@TextField #ResultValueField4 { @Anchor = (Width: 1, Height: 1); }
        $C.@TextField #ResultValueField5 { @Anchor = (Width: 1, Height: 1); }
      }

      Label #SelectedGuildLabel {
        Text: "";
        Style: (...$C.@DefaultLabelStyle, FontSize: 12);
        Anchor: (Bottom: 8);
      }
    }

    Group {
      LayoutMode: Top;
      Anchor: (Bottom: 10);

      Label {
        Text: %pixelbays.rpg.guild.applications.ui.applyHeading;
        Style: (...$C.@DefaultLabelStyle, RenderBold: true);
        Anchor: (Bottom: 6);
      }

      $C.@MultilineTextField #ApplicationReasonField {
        @Anchor = (Width: 820, Height: 110, Bottom: 8);
        PlaceholderText: %pixelbays.rpg.guild.applications.ui.reasonPlaceholder;
      }

      TextButton #ApplyButton {
        Visible: false;
        Text: %pixelbays.rpg.guild.applications.ui.applyButton;
        Style: $C.@DefaultTextButtonStyle;
        Anchor: (Width: 190, Height: 40);
      }
    }
  }
}

$C.@BackButton {}