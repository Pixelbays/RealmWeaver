$C = "../Common.ui";

$C.@PageOverlay {}

Group #LayoutRoot {
  Anchor: (Full: 0);

  Group #BrandPanel {
    LayoutMode: Left;
    Anchor: (Width: 340, Height: 56, Left: 56, Top: 20);
    Padding: (Full: 10);
    Background: PatchStyle(Color: #132033(0.94));
    OutlineColor: #4f7097ff;
    OutlineSize: 1;

    Group {
      Anchor: (Width: 52, Height: 36, Right: 10);
      Background: PatchStyle(Color: #29476c);
      OutlineColor: #87a7c8ff;
      OutlineSize: 1;
      LayoutMode: CenterMiddle;

      Label {
        Text: %pixelbays.rpg.character.ui.brandLogo;
        Style: (...$C.@DefaultLabelStyle, FontSize: 16, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
        Anchor: (Full: 0);
      }
    }

    Label #BrandTitleLabel {
      Text: %pixelbays.rpg.character.ui.brandTitle;
      Style: (...$C.@DefaultLabelStyle, FontSize: 14, RenderBold: true, VerticalAlignment: Center);
      FlexWeight: 1;
    }
  }

  Label #ModeLabel {
    Text: "";
    Style: (...$C.@DefaultLabelStyle, FontSize: 18, RenderBold: true, HorizontalAlignment: Center);
    Anchor: (Height: 28, Top: 26, Left: 0, Right: 0);
  }

  Label #StatusLabel {
    Text: "";
    Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true, HorizontalAlignment: Center, TextColor: #ff6666);
    Anchor: (Height: 22, Top: 54, Left: 0, Right: 0);
  }

  Group #LeftPanel {
    LayoutMode: Top;
    Anchor: (Width: 580, Left: 40, Top: 88, Bottom: 52);
    Padding: (Full: 8);
    Background: (TexturePath: "../Common/AvatarEditor/CategoryMenuPatch.png", Border: 16);

    Group #AppearanceLayout {
      LayoutMode: Left;
      Anchor: (Bottom: 12);
      FlexWeight: 1;
      Padding: (Left: 2, Right: 2, Top: 6);

      Group #CategoryRail {
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        Anchor: (Width: 60, Right: 12);
        Padding: (Top: 6, Bottom: 4);
      }

      Group {
        Anchor: (Width: 1, Top: 8, Bottom: 8, Right: 14);
        Background: #2b3542;
      }

      Group #CosmeticsColumn {
        LayoutMode: Top;
        FlexWeight: 1;
        Padding: (Top: 10, Right: 8);

        Label #CategoryHeadingLabel {
          Text: "";
          Style: (...$C.@DefaultLabelStyle, FontSize: 18, RenderBold: true, RenderUppercase: true, TextColor: #96a9be);
          Anchor: (Bottom: 8);
        }

        Group {
          Anchor: (Height: 1, Bottom: 10);
          Background: #2b3542;
        }

        Group {
          LayoutMode: Left;
          Anchor: (Height: 32, Bottom: 10);

          TextField #SearchField {
            Anchor: (Height: 32);
            FlexWeight: 1;
            PlaceholderText: %pixelbays.rpg.character.creator.searchPlaceholder;
            Style: (FontSize: 15, TextColor: #c3d1df);
            PlaceholderStyle: (TextColor: #4b576c, FontSize: 15);
            Padding: (Horizontal: 12, Left: 28);
            Decoration: (
              Default: (
                Background: (TexturePath: "../Common/AvatarEditor/SearchFieldPatch.png", Border: 8),
                Icon: (Texture: "../Common/AvatarEditor/SearchFieldIcon.png", Width: 15, Height: 15, Offset: 8)
              )
            );
          }

          Group {
            Anchor: (Width: 36, Height: 32, Left: 7);
            Background: (TexturePath: "../Common/AvatarEditor/ButtonPatch.png", Border: 16);
            LayoutMode: CenterMiddle;

            Group {
              Anchor: (Width: 15, Height: 17);
              Background: (TexturePath: "../Common/AvatarEditor/TagsIcon.png");
            }
          }
        }

        Group #CosmeticGrid {
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;
          Anchor: (Bottom: 16);
          FlexWeight: 1;
          Padding: (Right: 6);
        }

        Group #ColorSection {
          LayoutMode: Top;
          Visible: false;
          Anchor: (Height: 110, Bottom: 12);

          Label {
            Text: "COLOR";
            Style: (...$C.@DefaultLabelStyle, FontSize: 14, RenderBold: true, RenderUppercase: true, TextColor: #96a9be);
            Anchor: (Bottom: 6);
          }

          Group {
            Anchor: (Height: 1, Bottom: 10);
            Background: #2b3542;
          }

          Group #ColorList {
            LayoutMode: TopScrolling;
            ScrollbarStyle: $C.@DefaultScrollbarStyle;
            Anchor: (Height: 78, Top: 0);
            Padding: (Right: 4);
          }
        }

        Group #VariantSection {
          LayoutMode: Top;
          Visible: false;
          Anchor: (Height: 110, Bottom: 12);

          Label {
            Text: "OPTION";
            Style: (...$C.@DefaultLabelStyle, FontSize: 14, RenderBold: true, RenderUppercase: true, TextColor: #96a9be);
            Anchor: (Bottom: 6);
          }

          Group {
            Anchor: (Height: 1, Bottom: 10);
            Background: #2b3542;
          }

          Group #VariantList {
            LayoutMode: TopScrolling;
            ScrollbarStyle: $C.@DefaultScrollbarStyle;
            Anchor: (Height: 78, Top: 0);
            Padding: (Right: 4);
          }
        }
      }
    }

    Group {
      LayoutMode: Left;
      Anchor: (Height: 36);

      TextButton #RandomizeButton {
        Text: %pixelbays.rpg.character.creator.randomizeButton;
        Style: $C.@DefaultTextButtonStyle;
        Anchor: (Width: 220, Height: 36);
      }

      Group {
        FlexWeight: 1;
      }
    }
  }

  Group #RightInfoPanel {
    LayoutMode: Top;
    Anchor: (Width: 320, Height: 650, Right: 56, Top: 88);
    Padding: (Full: 12);
    Background: PatchStyle(Color: #132033(0.94));
    OutlineColor: #4f7097ff;
    OutlineSize: 1;

    Label {
      Text: %pixelbays.rpg.character.creator.characterInfoHeading;
      Style: (...$C.@DefaultLabelStyle, FontSize: 16, RenderBold: true);
      Anchor: (Bottom: 6);
    }

    Label {
      Text: %pixelbays.rpg.character.creator.characterInfoSubheading;
      Style: (...$C.@DefaultLabelStyle, FontSize: 12);
      Anchor: (Bottom: 12);
    }

    $C.@TextField #NameField {
      @Anchor = (Height: 38, Bottom: 8);
      PlaceholderText: %pixelbays.rpg.character.creator.namePlaceholder;
    }

    Label {
      Text: %pixelbays.rpg.character.creator.raceHeading;
      Style: (...$C.@DefaultLabelStyle, FontSize: 14, RenderBold: true);
      Anchor: (Bottom: 4);
    }

    Label #RaceSelectionLabel {
      Text: "";
      Style: (...$C.@DefaultLabelStyle, FontSize: 12);
      Anchor: (Bottom: 6);
    }

    Group #RaceList {
      LayoutMode: TopScrolling;
      ScrollbarStyle: $C.@DefaultScrollbarStyle;
      Anchor: (Height: 124, Bottom: 10);
      Padding: (Right: 4);
    }

    Label {
      Text: %pixelbays.rpg.character.creator.classHeading;
      Style: (...$C.@DefaultLabelStyle, FontSize: 14, RenderBold: true);
      Anchor: (Bottom: 4);
    }

    Label #ClassSelectionLabel {
      Text: "";
      Style: (...$C.@DefaultLabelStyle, FontSize: 12);
      Anchor: (Bottom: 6);
    }

    Group #ClassList {
      LayoutMode: TopScrolling;
      ScrollbarStyle: $C.@DefaultScrollbarStyle;
      Anchor: (Height: 138);
      Padding: (Right: 4);
    }

    Group #HardcoreSection {
      Visible: false;
      LayoutMode: Left;
      Anchor: (Height: 34, Top: 10);

      $C.@CheckBox #HardcoreCheck {
        Value: false;
        Anchor: (Width: 24, Height: 24, Top: 4, Right: 10);
      }

      Label {
        Text: %pixelbays.rpg.character.creator.hardcoreLabel;
        Style: (...$C.@DefaultLabelStyle, FontSize: 12, RenderBold: true);
        Anchor: (Top: 6);
      }
    }
  }

  Group #RightSummaryPanel {
    LayoutMode: Top;
    Anchor: (Width: 320, Height: 148, Right: 56, Bottom: 52);
    Padding: (Full: 12);
    Background: PatchStyle(Color: #132033(0.94));
    OutlineColor: #4f7097ff;
    OutlineSize: 1;

    Label {
      Text: %pixelbays.rpg.character.creator.summaryHeading;
      Style: (...$C.@DefaultLabelStyle, FontSize: 14, RenderBold: true);
      Anchor: (Bottom: 6);
    }

    Label #SummaryLabel {
      Text: "";
      Style: (...$C.@DefaultLabelStyle, FontSize: 12);
      Anchor: (Height: 70, Bottom: 10);
    }

    Group { FlexWeight: 1; }

    Label #CostLabel {
      Text: "";
      Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true);
    }
  }

  Group #CenterControls {
    LayoutMode: Bottom;
    Anchor: (Left: 652, Right: 420, Bottom: 52);

    Group {
      LayoutMode: Left;
      Anchor: (Height: 46, Bottom: 12);

      Group { FlexWeight: 1; }

      TextButton #RotateLeftButton {
        Text: "LEFT";
        Style: $C.@DefaultTextButtonStyle;
        Anchor: (Width: 54, Height: 46, Right: 8);
      }

      TextButton #RotateRightButton {
        Text: "RIGHT";
        Style: $C.@DefaultTextButtonStyle;
        Anchor: (Width: 54, Height: 46);
      }

      Group { FlexWeight: 1; }
    }

    Group #ActionRow {
      LayoutMode: Left;
      Anchor: (Height: 44);

      Group { FlexWeight: 1; }

      TextButton #BackButton {
        Text: %pixelbays.rpg.character.creator.backButton;
        Style: $C.@DefaultTextButtonStyle;
        Anchor: (Width: 180, Height: 44, Right: 8);
      }

      TextButton #ConfirmButton {
        Text: %pixelbays.rpg.character.creator.confirmButton;
        Style: $C.@DefaultTextButtonStyle;
        Anchor: (Width: 220, Height: 44);
      }

      Group { FlexWeight: 1; }
    }
  }

  Group #CreateConfirmOverlay {
    Visible: false;
    Anchor: (Full: 0);
    Background: PatchStyle(Color: #000000(0.62));
    LayoutMode: CenterMiddle;

    Group {
      LayoutMode: Top;
      Anchor: (Width: 420, Height: 212);
      Padding: (Full: 16);
      Background: PatchStyle(Color: #132033);
      OutlineColor: #4f7097ff;
      OutlineSize: 1;

      Label {
        Text: %pixelbays.rpg.character.creator.confirmPopupTitle;
        Style: (...$C.@DefaultLabelStyle, FontSize: 18, RenderBold: true, HorizontalAlignment: Center);
        Anchor: (Bottom: 10);
      }

      Label #CreateConfirmMessage {
        Text: "";
        Style: (...$C.@DefaultLabelStyle, FontSize: 13, HorizontalAlignment: Center, VerticalAlignment: Center);
        Anchor: (Height: 64, Bottom: 16);
      }

      Group { FlexWeight: 1; }

      Group {
        LayoutMode: Left;
        Anchor: (Height: 44);

        TextButton #CreateConfirmCancelButton {
          Text: %pixelbays.rpg.character.creator.confirmPopupCancel;
          Style: $C.@DefaultTextButtonStyle;
          Anchor: (Width: 198, Height: 44, Right: 8);
        }

        TextButton #CreateConfirmAcceptButton {
          Text: %pixelbays.rpg.character.creator.confirmPopupAccept;
          Style: $C.@DefaultTextButtonStyle;
          Anchor: (Width: 198, Height: 44);
        }
      }
    }
  }
}
