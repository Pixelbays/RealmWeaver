          Group {
            LayoutMode: Top;
            Anchor: (Width: 390, Bottom: 8);

            Group { LayoutMode: Left; Anchor: (Height: 28, Bottom: 4); $C.@CheckBox #InvitePermissionCheck { Value: false; Anchor: (Top: 4, Right: 8); } Label { Text: %pixelbays.rpg.guild.ui.permissionInvite; Style: (...$C.@DefaultLabelStyle, FontSize: 12); } }
            Group { LayoutMode: Left; Anchor: (Height: 28, Bottom: 4); $C.@CheckBox #KickPermissionCheck { Value: false; Anchor: (Top: 4, Right: 8); } Label { Text: %pixelbays.rpg.guild.ui.permissionKick; Style: (...$C.@DefaultLabelStyle, FontSize: 12); } }
            Group { LayoutMode: Left; Anchor: (Height: 28, Bottom: 4); $C.@CheckBox #PromotePermissionCheck { Value: false; Anchor: (Top: 4, Right: 8); } Label { Text: %pixelbays.rpg.guild.ui.permissionPromote; Style: (...$C.@DefaultLabelStyle, FontSize: 12); } }
            Group { LayoutMode: Left; Anchor: (Height: 28, Bottom: 4); $C.@CheckBox #ManageRolesPermissionCheck { Value: false; Anchor: (Top: 4, Right: 8); } Label { Text: %pixelbays.rpg.guild.ui.permissionManageRoles; Style: (...$C.@DefaultLabelStyle, FontSize: 12); } }
            Group { LayoutMode: Left; Anchor: (Height: 28, Bottom: 4); $C.@CheckBox #SetJoinPolicyPermissionCheck { Value: false; Anchor: (Top: 4, Right: 8); } Label { Text: %pixelbays.rpg.guild.ui.permissionSetJoinPolicy; Style: (...$C.@DefaultLabelStyle, FontSize: 12); } }
            Group { LayoutMode: Left; Anchor: (Height: 28, Bottom: 4); $C.@CheckBox #AcceptApplicationsPermissionCheck { Value: false; Anchor: (Top: 4, Right: 8); } Label { Text: %pixelbays.rpg.guild.ui.permissionAcceptApplications; Style: (...$C.@DefaultLabelStyle, FontSize: 12); } }
            Group { LayoutMode: Left; Anchor: (Height: 28, Bottom: 4); $C.@CheckBox #RejectApplicationsPermissionCheck { Value: false; Anchor: (Top: 4, Right: 8); } Label { Text: %pixelbays.rpg.guild.ui.permissionRejectApplications; Style: (...$C.@DefaultLabelStyle, FontSize: 12); } }
          }

          Group { Anchor: (Width: 16); }

          Group {
            LayoutMode: Top;
            Anchor: (Width: 390, Bottom: 8);

            Group { LayoutMode: Left; Anchor: (Height: 28, Bottom: 4); $C.@CheckBox #ManageGuildInfoPermissionCheck { Value: false; Anchor: (Top: 4, Right: 8); } Label { Text: %pixelbays.rpg.guild.ui.permissionManageGuildInfo; Style: (...$C.@DefaultLabelStyle, FontSize: 12); } }
            Group { LayoutMode: Left; Anchor: (Height: 28, Bottom: 4); $C.@CheckBox #ManageGuildBankPermissionCheck { Value: false; Anchor: (Top: 4, Right: 8); } Label { Text: %pixelbays.rpg.guild.ui.permissionManageGuildBank; Style: (...$C.@DefaultLabelStyle, FontSize: 12); } }
            Group { LayoutMode: Left; Anchor: (Height: 28, Bottom: 4); $C.@CheckBox #ManageGuildEventsPermissionCheck { Value: false; Anchor: (Top: 4, Right: 8); } Label { Text: %pixelbays.rpg.guild.ui.permissionManageGuildEvents; Style: (...$C.@DefaultLabelStyle, FontSize: 12); } }
            Group { LayoutMode: Left; Anchor: (Height: 28, Bottom: 4); $C.@CheckBox #ManageGuildWarPermissionCheck { Value: false; Anchor: (Top: 4, Right: 8); } Label { Text: %pixelbays.rpg.guild.ui.permissionManageGuildWar; Style: (...$C.@DefaultLabelStyle, FontSize: 12); } }
            Group { LayoutMode: Left; Anchor: (Height: 28, Bottom: 4); $C.@CheckBox #ManageGuildAlliancesPermissionCheck { Value: false; Anchor: (Top: 4, Right: 8); } Label { Text: %pixelbays.rpg.guild.ui.permissionManageGuildAlliances; Style: (...$C.@DefaultLabelStyle, FontSize: 12); } }
            Group { LayoutMode: Left; Anchor: (Height: 28, Bottom: 4); $C.@CheckBox #UseGuildChatPermissionCheck { Value: false; Anchor: (Top: 4, Right: 8); } Label { Text: %pixelbays.rpg.guild.ui.permissionUseGuildChat; Style: (...$C.@DefaultLabelStyle, FontSize: 12); } }
            Group { LayoutMode: Left; Anchor: (Height: 28, Bottom: 4); $C.@CheckBox #UseGuildBankPermissionCheck { Value: false; Anchor: (Top: 4, Right: 8); } Label { Text: %pixelbays.rpg.guild.ui.permissionUseGuildBank; Style: (...$C.@DefaultLabelStyle, FontSize: 12); } }
          }
        }

        TextButton #SaveRolePermissionsButton {
          Visible: false;
          Text: %pixelbays.rpg.guild.ui.saveRolePermissionsButton;
          Style: $C.@DefaultTextButtonStyle;
          Anchor: (Width: 220, Height: 40, Bottom: 8);
