        Anchor: (Height: 40, Bottom: 8);

        $C.@TextField #GuildField {
          @Anchor = (Width: 420, Height: 40);
          PlaceholderText: %pixelbays.rpg.ui.placeholder.guildNameOrTag;
        }

        Group { FlexWeight: 1; }

        TextButton #ApplyButton {
          Text: %pixelbays.rpg.guild.ui.applyButton;
          Style: $C.@DefaultTextButtonStyle;
          Anchor: (Width: 170, Height: 40);
        }
      }
    }

    Group #CalendarPanel {
      Visible: false;
      LayoutMode: Top;
      Anchor: (Bottom: 12);

      Label {
        Text: %pixelbays.rpg.guild.ui.calendarHeading;
        Style: (...$C.@DefaultLabelStyle, RenderBold: true);
        Anchor: (Bottom: 6);
      }

      Label #CalendarLabel {
        Text: "";
        Style: (...$C.@DefaultLabelStyle, FontSize: 12);
      }
    }

  }
}

Group #RosterModerationConfirmOverlay {
  Visible: false;
  Anchor: (Full: 0);
  Background: PatchStyle(Color: #000000(0.62));
  LayoutMode: CenterMiddle;

  Group {
    LayoutMode: Top;
    Anchor: (Width: 440, Height: 212);
    Padding: (Full: 16);
    Background: PatchStyle(Color: #132033);
    OutlineColor: #4f7097ff;
    OutlineSize: 1;

    Label #RosterModerationConfirmTitle {
      Text: %pixelbays.rpg.guild.ui.confirmActionTitle;
      Style: (...$C.@DefaultLabelStyle, FontSize: 18, RenderBold: true, HorizontalAlignment: Center);
      Anchor: (Bottom: 10);
    }

    Label #RosterModerationConfirmMessage {
      Text: "";
      Style: (...$C.@DefaultLabelStyle, FontSize: 13, HorizontalAlignment: Center, VerticalAlignment: Center);
      Anchor: (Height: 64, Bottom: 16);
    }

    Group { FlexWeight: 1; }

    Group {
      LayoutMode: Left;
      Anchor: (Height: 44);

      TextButton #RosterModerationConfirmCancelButton {
        Text: %pixelbays.rpg.guild.ui.confirmActionCancel;
        Style: $C.@DefaultTextButtonStyle;
        Anchor: (Width: 208, Height: 44, Right: 8);
      }

      TextButton #RosterModerationConfirmAcceptButton {
        Text: %pixelbays.rpg.guild.ui.confirmActionAccept;
        Style: $C.@DefaultTextButtonStyle;
        Anchor: (Width: 208, Height: 44);
      }
    }
  }
}

$C.@BackButton {}
