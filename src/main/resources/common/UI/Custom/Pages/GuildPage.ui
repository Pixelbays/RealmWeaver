            $C.@TextField #RoleEditorRoleField { @Anchor = (Width: 1, Height: 1); }
            $C.@TextField #RoleTabValueField1 { @Anchor = (Width: 1, Height: 1); }
            $C.@TextField #RoleTabValueField2 { @Anchor = (Width: 1, Height: 1); }
            $C.@TextField #RoleTabValueField3 { @Anchor = (Width: 1, Height: 1); }
