            }

            Group { Anchor: (Width: 8); }

            TextButton #RoleTabButton1 { Visible: false; Text: ""; Style: $C.@DefaultTextButtonStyle; Anchor: (Width: 106, Height: 40); }
            Group { Anchor: (Width: 8); }
            TextButton #RoleTabButton2 { Visible: false; Text: ""; Style: $C.@DefaultTextButtonStyle; Anchor: (Width: 106, Height: 40); }
            Group { Anchor: (Width: 8); }
            TextButton #RoleTabButton3 { Visible: false; Text: ""; Style: $C.@DefaultTextButtonStyle; Anchor: (Width: 106, Height: 40); }
            Group { Anchor: (Width: 8); }
            TextButton #RoleTabButton4 { Visible: false; Text: ""; Style: $C.@DefaultTextButtonStyle; Anchor: (Width: 106, Height: 40); }
