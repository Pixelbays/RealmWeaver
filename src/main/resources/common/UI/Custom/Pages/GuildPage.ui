$C = "../Common.ui";

$C.@PageOverlay {}
TabNavigation #GuildTabs {
  Style: $C.@TopTabsStyle;
  SelectedTab: "Tab1";
  Anchor: (Top: 100, Width: 800, Height: 100);
  // Basic Guild Info Tab, Name, Emblem, Description, Open Invites, how many members online, Message of the day, upcoming guild events, etc.
  TabButton #overviewTab {
    Icon: "icon.png";
    TooltipText: "Guild Overview";
    Id: "Tab1";
  }
  // Guild Roster Tab, List of members, their roles, online status, etc.
  TabButton #RosterTab {
    Icon: "icon.png";
    TooltipText: "Guild Roster";
    Id: "Tab2";
  }
  // Guild Invites Tab, List of pending invites, options to accept or decline invites, pending applications, etc. // and where to set if accecpting invites. 
  TabButton #InvitesTab {
    Icon: "icon.png";
    TooltipText: "Guild Invites";
    Id: "Tab3";
  }
  // Guild Calendar Tab, shows upcoming guild events, raids, meetings, etc. with options to RSVP or set reminders.
  TabButton #CalendarTab {
    Icon: "icon.png";
    TooltipText: "Guild Calendar";
    Id: "Tab4";
  }
    // Guild Management Tab - Only visible to players with appropriate permissions, options to manage guild settings, roles, permissions.
  TabButton #GuildManagementTab {
    Icon: "icon.png";
    TooltipText: "Guild Management";
    Id: "Tab5";
  }
   // Role Management Tab - Only visible to players with appropriate permissions, options to manage guild settings, roles, permissions.
  TabButton #RoleManagementTab {
    Icon: "icon.png";
    TooltipText: "Role Management";
    Id: "Tab6";
  }

}
$C.@DecoratedContainer {
  Anchor: (Width: 820, Height: 640);

  #Title {
    Group {
      $C.@Title {
        @Text = %pixelbays.rpg.guild.ui.title;
      }
    }
  }


  #Content {
    LayoutMode: Top;
    Padding: (Full: 12);


    Label #StatusLabel {
      Text: "";
      Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true);
      Anchor: (Bottom: 12);
    }

    Group #OverviewPanel {
      LayoutMode: Top;
      Anchor: (Bottom: 12);

      Label {
        Text: %pixelbays.rpg.guild.ui.overviewHeading;
        Style: (...$C.@DefaultLabelStyle, RenderBold: true);
        Anchor: (Bottom: 6);
      }

      Label #OverviewLabel {
        Text: "";
        Style: (...$C.@DefaultLabelStyle, FontSize: 12);
        Anchor: (Bottom: 6);
      }
    }

    Group #RosterPanel {
      Visible: false;
      LayoutMode: Top;
      Anchor: (Bottom: 12);

      Label {
        Text: %pixelbays.rpg.guild.ui.rosterHeading;
        Style: (...$C.@DefaultLabelStyle, RenderBold: true);
        Anchor: (Bottom: 6);
      }

      Label #RosterLabel {
        Text: "";
        Style: (...$C.@DefaultLabelStyle, FontSize: 12);
        Anchor: (Bottom: 8);
      }

      Group #RosterSelectionRow {
        Visible: false;
        LayoutMode: Left;
        Anchor: (Height: 40, Bottom: 8);

        Label {
          Text: %pixelbays.rpg.guild.ui.rosterMemberSelectLabel;
          Style: (...$C.@DefaultLabelStyle, FontSize: 12);
          Anchor: (Width: 150, Top: 12, Right: 8);
        }

        $C.@DropdownBox #RosterMemberDropdown {
          @Anchor = (Width: 610, Height: 40);
          NoItemsText: %pixelbays.rpg.guild.ui.rosterNoSelectableMembers;
        }
      }

      Group #RosterRoleRow {
        Visible: false;
        LayoutMode: Left;
        Anchor: (Height: 40, Bottom: 8);

        Label {
          Text: %pixelbays.rpg.guild.ui.rosterRoleSelectLabel;
          Style: (...$C.@DefaultLabelStyle, FontSize: 12);
          Anchor: (Width: 150, Top: 12, Right: 8);
        }

        $C.@DropdownBox #RosterRoleDropdown {
          @Anchor = (Width: 440, Height: 40);
          NoItemsText: %pixelbays.rpg.guild.ui.roleListEmpty;
        }

        Group { FlexWeight: 1; }

        TextButton #RosterAssignRoleButton {
          Text: %pixelbays.rpg.guild.ui.assignRoleButton;
          Style: $C.@DefaultTextButtonStyle;
          Anchor: (Width: 170, Height: 40);
        }
      }

      Group #RosterModerationRow {
        Visible: false;
        LayoutMode: Left;
        Anchor: (Height: 40, Bottom: 8);

        Group { Anchor: (Width: 158); }

        Group { FlexWeight: 1; }

        TextButton #RosterKickButton {
          Visible: false;
          Text: %pixelbays.rpg.guild.ui.kickButton;
          Style: $C.@DefaultTextButtonStyle;
          Anchor: (Width: 170, Height: 40);
        }

        Group { Anchor: (Width: 8); }

        TextButton #RosterPromoteButton {
          Visible: false;
          Text: %pixelbays.rpg.guild.ui.promoteLeaderButton;
          Style: $C.@DefaultTextButtonStyle;
          Anchor: (Width: 190, Height: 40);
        }
      }
    }

    Group #ManagementPanel {
      Visible: false;
      LayoutMode: Top;
      Anchor: (Bottom: 12);

      Label #ManagementHeadingLabel {
