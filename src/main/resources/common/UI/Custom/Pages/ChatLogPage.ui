$C = "../Common.ui";

$C.@PageOverlay {}

$C.@DecoratedContainer {
  Anchor: (Width: 1120, Height: 720);

  #Title {
    Group {
      $C.@Title {
        @Text = %pixelbays.rpg.chatlog.ui.title;
      }
    }
  }

  #Content {
    LayoutMode: Top;
    Padding: (Full: 12);

    Label #StatusLabel {
      Text: "";
      Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true);
      Anchor: (Bottom: 12);
    }

    Group #MainRow {
      LayoutMode: Left;
      Anchor: (Height: 560, Bottom: 12);

      Group #HistoryPanel {
        LayoutMode: Top;
        Anchor: (Width: 470, Height: 560, Right: 12);

        Label {
          Text: %pixelbays.rpg.chatlog.ui.historyHeading;
          Style: (...$C.@DefaultLabelStyle, FontSize: 16, RenderBold: true);
          Anchor: (Bottom: 6);
        }

        Label #TargetLabel {
          Text: "";
          Style: (...$C.@DefaultLabelStyle, FontSize: 12);
          Anchor: (Bottom: 10);
        }

        Label #SummaryLabel {
          Text: "";
          Style: (...$C.@DefaultLabelStyle, FontSize: 12);
          Anchor: (Bottom: 10);
        }

        Label #HistoryEmptyLabel {
          Visible: false;
          Text: %pixelbays.rpg.chatlog.ui.emptyHistory;
          Style: (...$C.@DefaultLabelStyle, FontSize: 12);
          Anchor: (Bottom: 12);
        }

        Group #HistoryEntryList {
          FlexWeight: 1;
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;
          Padding: (Right: 6);
          Background: #08101a(0.25);
          Anchor: (Bottom: 12);
        }

        Group #HistoryActionsRow {
          LayoutMode: Left;
          Anchor: (Height: 42);

          Group { FlexWeight: 1; }

          TextButton #RefreshButton {
            Text: %pixelbays.rpg.chatlog.ui.refreshButton;
            Style: $C.@DefaultTextButtonStyle;
            Anchor: (Width: 130, Height: 42);
          }
        }
      }

      Group #DetailPanel {
        LayoutMode: Top;
        Anchor: (Width: 626, Height: 560);

        Label {
          Text: %pixelbays.rpg.chatlog.ui.detailHeading;
          Style: (...$C.@DefaultLabelStyle, FontSize: 16, RenderBold: true);
          Anchor: (Bottom: 6);
        }

        Group #DetailScroll {
          FlexWeight: 1;
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;
          Padding: (Right: 6);
          Background: #08101a(0.25);

          Label #DetailHeaderLabel {
            Text: "";
            Style: (...$C.@DefaultLabelStyle, FontSize: 18, RenderBold: true);
            Anchor: (Bottom: 8);
          }

          Label #DetailMetaLabel {
            Text: "";
            Style: (...$C.@DefaultLabelStyle, FontSize: 12);
            Anchor: (Bottom: 12);
          }

          Label #DetailBodyLabel {
            Text: "";
            Style: (...$C.@DefaultLabelStyle, FontSize: 12);
            Anchor: (Bottom: 12);
          }
        }
      }
    }
  }
}

$C.@BackButton {}